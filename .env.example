# ============================================
# DocuMind-AI — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- LLM Provider ---
# Options: "groq" or "ollama"
LLM_PROVIDER=groq

# --- Groq API (if LLM_PROVIDER=groq) ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (if LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Chunking ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- Retrieval ---
TOP_K=5

# --- Server ---
HOST=0.0.0.0
PORT=8000
